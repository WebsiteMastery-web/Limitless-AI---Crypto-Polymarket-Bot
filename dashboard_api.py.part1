# === HELPER FUNCTIONS ===


def load_jsonl(filepath, limit=100):
    """Load entries from JSONL file, newest first."""
    entries = []
    if not filepath.exists():
        return entries
    try:
        with open(filepath, "r") as f:
            lines = f.readlines()
        for line in reversed(lines[-limit:]):
            try:
                entries.append(json.loads(line.strip()))
            except:
                continue
    except Exception as e:
        print(f"Error loading {filepath}: {e}")
    return entries


def load_json(filepath, default=None):
    """Load JSON file, return default if missing."""
    if not filepath.exists():
        return default
    try:
        with open(filepath, "r") as f:
            return json.load(f)
    except:
        return default


def save_json(filepath, data):
    """Save data to JSON file."""
    try:
        filepath.parent.mkdir(parents=True, exist_ok=True)
        with open(filepath, "w") as f:
            json.dump(data, f, indent=2)
        return True
    except Exception as e:
        print(f"Error saving {filepath}: {e}")
        return False


def format_time_ago(timestamp):
    """Format timestamp as human-readable time ago."""
    try:
        dt = datetime.fromisoformat(timestamp.replace("Z", "+00:00"))
        now = datetime.now(dt.tzinfo)
        delta = now - dt
        mins = int(delta.total_seconds() / 60)
        if mins < 60:
            return f"{mins}m ago"
        hours = mins // 60
        if hours < 24:
            return f"{hours}h ago"
        days = hours // 24
        return f"{days}d ago"
    except:
        return timestamp[:19] if len(timestamp) > 19 else timestamp


def format_price(price):
    """Format price with $ and commas."""
    try:
        return f"${float(price):,.2f}"
    except:
        return str(price)


def get_kb_files():
    """Get knowledge base file status."""
    files = []
    if not KB_DIR.exists():
        return files
    for f in sorted(KB_DIR.glob("*.md")):
        try:
            stat = f.stat()
            age_days = (datetime.now() - datetime.fromtimestamp(stat.st_mtime)).days
            preview = ""
            try:
                with open(f, "r") as fp:
                    preview = fp.read(100).replace("\n", " ")
            except:
                pass
            files.append(
                {
                    "name": f.name,
                    "size": stat.st_size,
                    "age_days": age_days,
                    "preview": preview,
                    "warning": stat.st_size < 500 or age_days > 8,
                }
            )
        except:
            continue
    return files


def get_system_health():
    """Get system health status."""
    health = {}

    # MiroFish
    try:
        resp = requests.get("http://localhost:9876/health", timeout=2)
        health["mirofish"] = (
            ("ok" in resp.text.lower()) if resp.status_code == 200 else False
        )
    except:
        health["mirofish"] = False

    # Dashboard
    health["dashboard"] = True

    # Alpaca
    try:
        from alpaca.trading.client import TradingClient

        env = load_json(BASE_DIR / "TradingAgents" / ".env", {})
        api_key = env.get("APCA_API_KEY_ID") or os.getenv("APCA_API_KEY_ID")
        secret = env.get("APCA_API_SECRET_KEY") or os.getenv("APCA_API_SECRET_KEY")
        if api_key and secret:
            client = TradingClient(api_key, secret, paper=True)
            client.get_account()
            health["alpaca"] = True
        else:
            health["alpaca"] = False
    except:
        health["alpaca"] = False

    # OpenRouter
    try:
        env = load_json(BASE_DIR / "TradingAgents" / ".env", {})
        openrouter_key = env.get("OPENROUTER_API_KEY") or os.getenv(
            "OPENROUTER_API_KEY"
        )
        health["openrouter"] = bool(openrouter_key)
    except:
        health["openrouter"] = False

    # Cron
    try:
        result = subprocess.run(["crontab", "-l"], capture_output=True, text=True)
        health["cron"] = "run_cron.sh" in result.stdout
    except:
        health["cron"] = False

    # Pipeline log
    pipeline_log = LOGS_DIR / "pipeline_runs.jsonl"
    health["pipeline_log"] = pipeline_log.exists()

    # KB files
    kb_files = get_kb_files()
    health["kb_fresh"] = len(kb_files) > 0 and all(
        not f.get("warning", False) for f in kb_files
    )

    # Disk space
    try:
        result = subprocess.run(["df", "-h", "/"], capture_output=True, text=True)
        parts = result.stdout.strip().split()
        if len(parts) >= 5:
            avail = parts[3]
            health["disk"] = True
        else:
            health["disk"] = False
    except:
        health["disk"] = False

    return health


def check_cron_switch():
    """Check and perform cron switch based on win rate."""
    backtest_file = LOGS_DIR / "backtest_summary.json"
    cron_switch_file = LOGS_DIR / "cron_switch.json"

    if cron_switch_file.exists():
        return  # Already switched

    backtest = load_json(backtest_file, {})
    win_rate = backtest.get("win_rate_pct", 0)

    if win_rate > 55:
        # Switch cron to hourly
        try:
            result = subprocess.run(["crontab", "-l"], capture_output=True, text=True)
            lines = result.stdout.strip().split("\n")
            new_lines = []
            switched = False
            for line in lines:
                if "*/4" in line and "run_cron.sh" in line:
                    new_lines.append(
                        "0 * * * * cd /root/limitless-ai && bash run_cron.sh >> logs/cron.log 2>&1"
                    )
                    switched = True
                else:
                    new_lines.append(line)

            if switched:
                new_crontab = "\n".join(new_lines)
                subprocess.run(["crontab", "-"], input=new_crontab, text=True)
                save_json(
                    cron_switch_file,
                    {
                        "cron_switched": True,
                        "switched_at": datetime.now().isoformat(),
                        "win_rate": win_rate,
                    },
                )
        except Exception as e:
            print(f"Error switching cron: {e}")


