# Task 3: Knowledge Base Layer 9 loader
def load_knowledge_base():
    kb_dir = "/root/limitless-ai/knowledge_base"
    kb_context = ""
    try:
        import glob
        md_files = sorted(glob.glob(f"{kb_dir}/*.md"))
        if not md_files:
            logger.warning("KB Layer 9: No .md files found in knowledge_base/")
            return ""
        parts = []
        for fpath in md_files:
            fname = os.path.basename(fpath)
            with open(fpath, "r", encoding="utf-8") as f:
                content = f.read()
            parts.append(f"=== KB FILE: {fname} ===\n{content}\n")
        kb_context = "\n".join(parts)
        logger.info(f"KB Layer 9: Loaded {len(md_files)} files | {len(kb_context)/1024:.1f}KB total")
    except Exception as e:
        logger.error(f"KB Layer 9 load error: {e}")
    return kb_context

